<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">


<mapper namespace="com.ssm.mapper.AdminMapper">

    <!-- 登录查询 -->
    <select id="login" parameterType="com.ssm.entity.Admin" resultType="com.ssm.entity.Admin">
        select * from admin
        where username = #{username} and password = #{password}
    </select>


    <select id="findByUsername" parameterType="string" resultType="com.ssm.entity.Admin">
        select * from admin where username = #{username}
    </select>

    <!-- 注册插入 -->
    <insert id="register" parameterType="com.ssm.entity.Admin">
        insert into admin(username, password)
        values(#{username}, #{password})
    </insert>

</mapper>