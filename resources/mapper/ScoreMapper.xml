<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ssm.mapper.ScoreMapper">
    <select id="findByStuId" resultType="com.ssm.entity.Score">
        select * from score where stu_id = #{stuId}
    </select>

    <insert id="add">
        insert into score(stu_id, course, score) values(#{stuId}, #{course}, #{score})
    </insert>

    <update id="update">
        update score set course=#{course}, score=#{score} where id=#{id}
    </update>

    <delete id="delete">
        delete from score where id=#{id}
    </delete>

    <select id="findById" resultType="com.ssm.entity.Score">
        select * from score where id = #{id}
    </select>

    <select id="countByStuIdAndCourseExcludeId" resultType="int">
        select count(*) from score
        where stu_id = #{stuId} and course = #{course}
        <if test="id != null">
            and id != #{id}
        </if>
    </select>
</mapper>